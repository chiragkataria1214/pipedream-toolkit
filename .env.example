# Pipedream API key — https://pipedream.com/settings/api-keys
PIPEDREAM_API_KEY=

# Workspace / org id — find it in your Pipedream workspace settings (looks like o_xxxxxxx)
PIPEDREAM_ORG_ID=

# Optional: default project id to deploy new workflows into
# PIPEDREAM_PROJECT_ID=

# Optional: where exports are written (default: exported_workflows)
# EXPORT_DIR=exported_workflows
